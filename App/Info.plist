<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleDisplayName</key>
	<string>Otterpace</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<!-- Wake the app for the opt-in server-driven movement nudge (APNs). Only used
	     when the user is signed in, has health sync on, and granted push. -->
	<key>UIBackgroundModes</key>
	<array>
		<string>remote-notification</string>
	</array>
	<!-- Otterpace uses only standard HTTPS/TLS (export-exempt), so App Store
	     uploads skip the export-compliance prompt. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<key>NSHealthShareUsageDescription</key>
	<string>Otterpace reads your steps, distance, and active energy from Apple Health — on your device — so Buddy can coach you toward your daily goal without overtraining.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Otterpace only reads your activity from Apple Health to coach you — it does not write any data back to Health.</string>
	<!-- OAuth redirect target for "Connect Strava" (otterpace://strava-callback). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>com.otterpace.app.strava</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>otterpace</string>
			</array>
		</dict>
	</array>
	<!-- Strava import is hidden in v1 ON PURPOSE. The Settings "Strava" card only
	     renders when StravaConfig.isConfigured is true, i.e. when StravaClientID is
	     non-empty (see Sources/AppCore/Strava/StravaService.swift). Leaving this empty
	     keeps the whole flow hidden and makes zero Strava network calls — which is what
	     keeps the build review-safe. Do NOT populate this until the backend OAuth secret
	     is provisioned for /api/strava/*; a filled client ID with no working backend would
	     surface a "Connect Strava" button that fails (an App Store Guideline 2.1 reject). -->
	<key>StravaClientID</key>
	<string></string>
	<!-- PostHog analytics key — safe to leave empty (analytics simply no-ops). -->
	<key>PostHogProjectKey</key>
	<string></string>
	<key>PostHogHost</key>
	<string>https://us.i.posthog.com</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<true/>
	</dict>
	<key>UILaunchScreen</key>
	<dict>
		<key>UIColorName</key>
		<string>LaunchBackground</string>
		<key>UIImageName</key>
		<string>LaunchBuddy</string>
		<key>UIImageRespectsSafeAreaInsets</key>
		<true/>
	</dict>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
</dict>
</plist>
